{
  "name": "sqfts",
  "displayName": "SQFts",
  "description": "Gradually-typed SQF language support (diagnostics, hover, completion)",
  "version": "0.1.0",
  "publisher": "sqfts",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": [
    "onLanguage:sqfts"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sqfts",
        "aliases": ["SQFts", "sqfts"],
        "extensions": [".sqfts", ".d.sqfts"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sqfts",
        "scopeName": "source.sqfts",
        "path": "./syntaxes/sqfts.tmLanguage.json"
      },
      {
        "scopeName": "source.sqfts.engine-commands",
        "path": "./syntaxes/engine-commands.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "SQFts",
      "properties": {
        "sqfts.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to sqfts-language-server binary. Empty = bundled binary, then PATH."
        },
        "sqfts.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "gen-grammar": "node scripts/gen-grammar-commands.js",
    "build": "npm run gen-grammar && esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "npm run build && npm run copy-server:win && vsce package --no-dependencies --allow-missing-repository",
    "copy-server:win": "node scripts/copy-server.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
